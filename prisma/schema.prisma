generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  babies        Baby[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Baby {
  id        String   @id @default(cuid())
  name      String
  birthday  String
  gender    String
  avatar    String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  growthRecords     GrowthRecord[]
  feedingRecords   FeedingRecord[]
  sleepRecords     SleepRecord[]
  milestones       Milestone[]
  healthRecords    HealthRecord[]
  moodRecords      MoodRecord[]
  educationRecords EducationRecord[]
}

model GrowthRecord {
  id        String   @id @default(cuid())
  date      String
  height    Float
  weight    Float
  headCirc  Float
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model FeedingRecord {
  id        String   @id @default(cuid())
  date      String
  time      String
  type      String
  amount    Int?
  food      String?
  duration  Int?
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model SleepRecord {
  id        String   @id @default(cuid())
  date      String
  startTime String
  endTime   String
  duration  Int
  quality   String
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model Milestone {
  id           String   @id @default(cuid())
  type         String
  achievedDate String
  notes        String?
  babyId       String
  baby         Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([babyId])
  @@index([achievedDate])
}

model HealthRecord {
  id        String   @id @default(cuid())
  date      String
  type      String
  title     String
  details   String
  nextDate  String?
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model MoodRecord {
  id        String   @id @default(cuid())
  date      String
  time      String
  mood      String
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model EducationRecord {
  id          String   @id @default(cuid())
  date        String
  time        String
  type        String
  duration    Int
  description String?
  babyId      String
  baby        Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([babyId])
  @@index([date])
}
