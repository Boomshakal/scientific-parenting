generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  babies        Baby[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Baby {
  id        String   @id @default(cuid())
  name      String
  birthday  DateTime
  gender    String
  avatar    String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  growthRecords     GrowthRecord[]
  feedingRecords   FeedingRecord[]
  sleepRecords     SleepRecord[]
  milestones       Milestone[]
  healthRecords    HealthRecord[]
  moodRecords      MoodRecord[]
  educationRecords EducationRecord[]
  illnessEpisodes  IllnessEpisode[]
}

model GrowthRecord {
  id        String   @id @default(cuid())
  date      String
  height    Float
  weight    Float
  headCirc  Float
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model FeedingRecord {
  id        String   @id @default(cuid())
  date      String
  time      String
  type      String
  amount    Int?
  food      String?
  duration  Int?
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model SleepRecord {
  id        String   @id @default(cuid())
  date      String
  startTime String
  endTime   String
  duration  Int
  quality   String
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model Milestone {
  id           String   @id @default(cuid())
  type         String
  achievedDate String
  notes        String?
  babyId       String
  baby         Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([babyId])
  @@index([achievedDate])
}

model HealthRecord {
  id        String   @id @default(cuid())
  date      String
  type      String
  title     String
  details   String
  nextDate  String?
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model MoodRecord {
  id        String   @id @default(cuid())
  date      String
  time      String
  mood      String
  notes     String?
  babyId    String
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

model EducationRecord {
  id          String   @id @default(cuid())
  date        String
  time        String
  type        String
  duration    Int
  description String?
  babyId      String
  baby        Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([babyId])
  @@index([date])
}

// Illness tracking models
model IllnessEpisode {
  id          String   @id @default(cuid())
  title       String
  start_date  String
  end_date    String?
  description String?
  babyId      String
  baby        Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  records     IllnessRecord[]
  medications Medication[]
  doctorVisits DoctorVisit[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([babyId])
  @@index([start_date])
}

model IllnessRecord {
  id              String   @id @default(cuid())
  episodeId       String
  recorded_at     String  // ISO datetime
  symptoms        String  // JSON string of symptom strings
  temperature     Float?   // Celsius, 35.0-42.0
  temperature_method String? // oral, axillary, ear, temporal
  appetite        String?  // good, fair, poor
  sleep_quality   String?  // good, fair, poor
  mood            String?  // normal, irritable, lethargic
  notes           String?
  episode         IllnessEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([episodeId])
  @@index([recorded_at])
}

model Medication {
  id              String   @id @default(cuid())
  episodeId       String
  name            String
  dosage          String
  frequency       String
  route           String?  // oral, topical, injection
  start_date      String
  end_date        String?
  prescribed_by   String?
  notes           String?
  episode         IllnessEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([episodeId])
  @@index([start_date])
}

model DoctorVisit {
  id              String   @id @default(cuid())
  episodeId       String
  visit_date      String  // ISO datetime
  hospital        String?
  department      String?
  doctor          String?
  diagnosis       String?
  prescription    String?
  advice          String?
  attachments     String? // JSON string of URLs or file paths
  episode         IllnessEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([episodeId])
  @@index([visit_date])
}
